# ── Supabase ──────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Sentry (optional, leave empty to skip) ────────────────────
VITE_SENTRY_DSN=

# ── KYC provider toggle ───────────────────────────────────────
# Set to "didit" to use Didit verification, "manual" (or unset) to
# fall back to the legacy manual review flow in KYCSheet.
# Server-side Didit secrets are configured via:
#   supabase secrets set DIDIT_API_KEY=...
#   supabase secrets set DIDIT_WEBHOOK_SECRET=...
#   supabase secrets set DIDIT_WORKFLOW_ID_T2=...
#   supabase secrets set DIDIT_WORKFLOW_ID_T3=...
#   supabase secrets set APP_URL=https://www.b1n0.com
VITE_KYC_PROVIDER=manual
