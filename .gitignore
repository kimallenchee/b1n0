# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Environment
.env
.env.local

# Claude
.claude/

# Supabase local
supabase/.temp/

# Test artifacts
playwright-report/
test-results/

# Vercel CLI build output (when using `vercel build --prebuilt`)
.vercel/

# Stale editor/backup files — kept out of the repo so they don't
# pollute diffs. Past hits included src/index.css.bak from the OneDrive
# corruption recovery and .env.example.bak from a manual save.
*.bak

# Debug/scratch leftovers — covers the served.js / *.log noise that
# accumulates from ad-hoc curl downloads and SQL exports.
served.js
scratch.*

# Temporary PDF-page exports — generated by `pdftoppm` during visual QA
# of generated PDFs (investor memo, confianza). Always disposable.
page-*.jpg
page-*.png

# Generated PDFs in repo root (the actual public PDF lives under
# public/docs/ which IS committed; this guards against scratch builds
# landing at root by accident).
/*.pdf
/*.pptx
